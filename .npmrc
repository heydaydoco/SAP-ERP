# Hoist nothing implicitly; keep workspace deps strict.
auto-install-peers=true
strict-peer-dependencies=false
# ESLint resolves its plugins/parser from the package cwd; the shared flat config in
# @erp/config pulls them in transitively, so hoist *eslint* to the workspace root to make
# `pnpm lint` resolve identically in every workspace (turbo runs lint per package).
public-hoist-pattern[]=*eslint*
# Allow build scripts for known native/build-step packages only.
enable-pre-post-scripts=true
