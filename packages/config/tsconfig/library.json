{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Library (packages/*) — CommonJS dist for Node/Nest runtime",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": false,
    "isolatedModules": false
  }
}
