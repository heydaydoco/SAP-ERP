{
  "openapi": "3.0.0",
  "info": {
    "title": "SAP-ERP API",
    "version": "0.0.0",
    "description": "Generated from the api Zod DTOs via zod-to-openapi. Scoped subset for the web FI verification slice; extend apps/api/src/openapi/registry.ts and rerun `pnpm openapi`."
  },
