              "type": "integer",
              "minimum": 1,
              "maximum": 12
            },
            "required": false,
            "name": "periodNo",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "docType": {
                            "type": "string"
                          },
                          "docNo": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string"
                          },
                          "postingDate": {
                            "type": "string"
                          },
                          "documentDate": {
                            "type": "string"
                          },
                          "currency": {
                            "type": "string"
                          },
                          "functionalCurrency": {
                            "type": "string"
                          },
                          "fxRate": {
                            "type": "string",
                            "nullable": true
                          },
                          "reference": {
                            "type": "string"
                          },
                          "headerText": {
                            "type": "string",
                            "nullable": true
                          },
                          "fiscalYear": {
                            "type": "number"
                          },
                          "periodNo": {
                            "type": "number"
                          },
                          "companyCodeId": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "docType",
                          "docNo",
                          "status",
                          "postingDate",
                          "documentDate",
                          "currency",
                          "functionalCurrency",
                          "fxRate",
                          "reference",
                          "headerText",
                          "fiscalYear",
                          "periodNo",
                          "companyCodeId"
                        ]
                      }
                    },
                    "total": {
                      "type": "number"
                    },
                    "page": {
                      "type": "number"
                    },
                    "pageSize": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "data",
                    "total",
                    "page",
                    "pageSize"
                  ]
                }
              }
            }
          }
        }
      }
