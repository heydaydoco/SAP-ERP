{
  "name": "sap-erp",
  "version": "0.0.0",
  "private": true,
  "description": "Full enterprise ERP (40-person manufacturing / import-export B2B) — SAP-module-modeled, 4PL logistics deepened. TypeScript modular monolith.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "vitest run",
    "test:integration": "turbo run test:integration",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @erp/db db:generate",
    "db:migrate": "pnpm --filter @erp/db db:migrate",
    "seed": "pnpm --filter @erp/api seed",
    "openapi": "pnpm --filter @erp/api build && pnpm --filter @erp/api openapi:gen && pnpm --filter @erp/api-client gen:types",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.0"
    }
  },
  "devDependencies": {
    "@erp/config": "workspace:*",
    "@playwright/test": "^1.49.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
